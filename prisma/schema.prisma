generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

enum Role {
  SUPER_ADMIN
  MANAGER
  AUDITOR
}

enum ProjectStatus {
  PLANNING
  ACTIVE
  COMPLETED
}

enum CustomerStatus {
  ACTIVE
  COMPLETED
  CANCELLED
  PAUSED
  SHARE_TO_SELL
  TRANSFERRED
}

enum PaymentStatus {
  PENDING
  PAID
  OVERDUE
}

enum PaymentPurpose {
  DOWNPAYMENT
  INSTALLMENT
  UTILITIES
  SAND_FILLING
  DOCUMENT_VERIFICATION
  MISCELLANEOUS
  FULL_SETTLEMENT
}

enum PaymentPlan {
  INSTALLMENT
  FULL_UPFRONT
}

enum SettlementStatus {
  NONE
  FULLY_SETTLED
  EARLY_SETTLED
}

enum SettlementType {
  FULL_AT_ENROLLMENT
  EARLY_PAYOFF
  FULL_UPFRONT
}

enum PaymentMethod {
  BANK_TRANSFER
  CASH
  MOBILE_BANKING
}

enum ShareAllocationStatus {
  AVAILABLE
  RESERVED
  ALLOCATED
  TRANSFERRED
}

enum GraceStatus {
  NONE
  PAUSED
  RECALCULATED
}

enum PricingMode {
  STANDARD
  CUSTOM
  MIXED_PHASE
}

enum PricingSource {
  PHASE_DEFAULT
  TWIN_COMBO
  CUSTOM_OVERRIDE
  MANUAL_ADJUSTMENT
}

enum VerificationStatus {
  PENDING
  VERIFIED
  REJECTED
}

enum ExpenseCategory {
  PRE_OPERATIONAL_LEGAL
  OFFICE_OPERATIONS
  BRANDING_MARKETING
  HR_CONSULTANCY
}

enum ApprovingPartner {
  ADMIN
  MANIK
}

enum ReceiptStatus {
  ACTIVE
  VOIDED
}

enum LeadStatus {
  NEW
  CONTACTED
  SITE_VISIT
  NEGOTIATING
  CONVERTED
  LOST
}

enum LeadSource {
  WALK_IN
  PHONE
  WHATSAPP
  REFERRAL
  FACEBOOK
  OTHER
}

enum RegistrationStage {
  NOT_STARTED
  AGREEMENT_SIGNED
  DEED_PREPARATION
  MUTATION_PENDING
  MUTATION_DONE
  REGISTRY_PENDING
  REGISTRY_DONE
  HANDOVER_DONE
}

enum ReminderType {
  FOLLOW_UP
  SITE_VISIT
  INSTALLMENT_DUE
  DOCUMENT
  REGISTRATION
  CUSTOM
}

enum ReminderStatus {
  PENDING
  DONE
  CANCELLED
}

enum CommissionStatus {
  PENDING
  APPROVED
  PAID
  CANCELLED
}

enum CommissionBasis {
  ENROLLMENT
  DOWNPAYMENT
  PAYMENT
  MANUAL
}

enum DeveloperAgreementStatus {
  DRAFT
  SIGNED
  IN_PROGRESS
  COMPLETED
  CANCELLED
}

enum FlatStatus {
  PLANNED
  AVAILABLE
  RESERVED
  ALLOCATED
  HANDED_OVER
}

enum HandoverStatus {
  NOT_STARTED
  IN_PROGRESS
  COMPLETED
}

model User {
  id           String   @id @default(cuid())
  email        String   @unique
  passwordHash String
  name         String
  role         Role     @default(MANAGER)
  createdAt    DateTime @default(now())
  updatedAt    DateTime @updatedAt

  auditLogs            AuditLog[]
  settlementsPerformed   PaymentSettlement[] @relation("SettledBy")
  contractAdjustments  ContractAdjustmentLog[]
  customerNotes        CustomerNote[]
  expensesRecorded     CompanyExpense[]
  assignedLeads        Lead[]                @relation("LeadAssignee")
  remindersCreated     Reminder[]
  linkedSalesAgent     SalesAgent?
  landValuations       LandValuation[]
  handoversRecorded    Handover[]            @relation("HandoverRecorder")
}

model VendorCompany {
  id            String   @id @default(cuid())
  name          String   @unique
  nameBn        String?
  contactPerson String?
  phone         String?
  address       String?
  notes         String?
  createdAt     DateTime @default(now())
  updatedAt     DateTime @updatedAt

  projects Project[]
}

model Project {
  id                String        @id @default(cuid())
  prefix            String        @unique
  name              String
  nameBn            String?
  status            ProjectStatus @default(PLANNING)
  installmentMonths Int           @default(48)
  totalShares       Int           @default(72)
  publicShares      Int           @default(60)
  dimensions        String        @default("{}")
  layouts           String        @default("{}")
  pricingPhases     String        @default("[]")
  vendorCompanyId   String?
  landBuyPrice      Float?
  targetSellPrice   Float?
  companyPaidAmount Float         @default(0)
  dealStartDate     DateTime?
  dealEndDate       DateTime?
  acquisitionNotes  String?
  createdAt         DateTime      @default(now())
  updatedAt         DateTime      @updatedAt

  vendorCompany   VendorCompany? @relation(fields: [vendorCompanyId], references: [id])
  shares          Share[]
  customers       Customer[]
  documents       Document[]
  serialCounters  ProjectSerialCounter[]
  expenses        CompanyExpense[]
  leads           Lead[]
  commissions     Commission[]
  landValuations  LandValuation[]
  developerAgreements DeveloperAgreement[]
  flats           Flat[]
  handovers       Handover[]
}

model ProjectSerialCounter {
  id         String  @id @default(cuid())
  projectId  String
  year       Int
  lastSerial Int     @default(0)
  project    Project @relation(fields: [projectId], references: [id], onDelete: Cascade)

  @@unique([projectId, year])
}

model Share {
  id               String                @id @default(cuid())
  projectId        String
  shareNumber      Int
  allocationStatus ShareAllocationStatus @default(AVAILABLE)
  activeCustomerId String?
  reservedUntil    DateTime?
  createdAt        DateTime              @default(now())
  updatedAt        DateTime              @updatedAt

  project        Project         @relation(fields: [projectId], references: [id], onDelete: Cascade)
  activeCustomer Customer?       @relation("ActiveShareHolder", fields: [activeCustomerId], references: [id])
  allocations    CustomerShare[]
  transferLogs   ShareTransferLog[]
  flatLinks      FlatShareLink[]

  @@unique([projectId, shareNumber])
}

model CustomerProfile {
  id                 String   @id @default(cuid())
  fullName           String
  phone              String   @unique
  email              String?
  nid                String?
  address            String?
  passwordHash            String?
  portalTemporaryPassword String?
  mustChangePassword      Boolean  @default(false)
  passwordChangedAt       DateTime?
  createdAt          DateTime @default(now())
  updatedAt          DateTime @updatedAt

  enrollments       Customer[]
  portalResetTokens PortalPasswordReset[]
}

model PortalPasswordReset {
  id         String   @id @default(cuid())
  profileId  String
  tokenHash  String   @unique
  expiresAt  DateTime
  usedAt     DateTime?
  createdAt  DateTime @default(now())

  profile CustomerProfile @relation(fields: [profileId], references: [id], onDelete: Cascade)

  @@index([profileId, expiresAt])
}

model Customer {
  id                 String             @id @default(cuid())
  trackingId         String             @unique
  profileId          String?
  projectId          String
  status             CustomerStatus     @default(ACTIVE)
  shareCount         Int                @default(0)
  fullName           String
  phone              String
  email              String?
  nid                String?
  address            String?
  predecessorId      String?
  paymentPlan        PaymentPlan        @default(INSTALLMENT)
  settlementStatus   SettlementStatus   @default(NONE)
  graceStatus        GraceStatus        @default(NONE)
  isPaused           Boolean            @default(false)
  verificationStatus VerificationStatus @default(PENDING)
  registrationStage  RegistrationStage  @default(NOT_STARTED)
  registrationNotes  String?
  registrationUpdatedAt DateTime?
  salesAgentId       String?
  contractStartDate  DateTime?
  createdAt          DateTime           @default(now())
  updatedAt          DateTime           @updatedAt

  project        Project              @relation(fields: [projectId], references: [id])
  profile        CustomerProfile?     @relation(fields: [profileId], references: [id])
  predecessor    Customer?            @relation("CustomerSuccessor", fields: [predecessorId], references: [id])
  successors     Customer[]           @relation("CustomerSuccessor")
  contract       CustomerContract?
  shareAllocations CustomerShare[]
  paymentLedgers PaymentLedger[]
  settlements    PaymentSettlement[]
  receipts       MoneyReceipt[]
  documents      Document[]
  notes          CustomerNote[]
  activeShares   Share[]              @relation("ActiveShareHolder")
  transfersFrom  ShareTransferLog[]   @relation("TransferFrom")
  transfersTo    ShareTransferLog[]   @relation("TransferTo")
  sourceLeads    Lead[]               @relation("LeadConvertedCustomer")
  reminders      Reminder[]
  salesAgent     SalesAgent?          @relation(fields: [salesAgentId], references: [id])
  commissions    Commission[]
  flats          Flat[]
  handovers      Handover[]
}

model CustomerContract {
  id                      String      @id @default(cuid())
  customerId              String      @unique
  pricingMode             PricingMode @default(STANDARD)
  useComboOffer           Boolean     @default(false)
  customTotalPrice        Float?
  customDownpayment       Float?
  customMonthlyAmount     Float?
  customInstallmentMonths Int?
  discountAmount          Float?
  discountReason          String?
  approvedByUserId        String
  approvedAt              DateTime    @default(now())
  contractStartDate       DateTime    @default(now())
  effectiveFrom           DateTime    @default(now())
  notes                   String?

  customer    Customer                  @relation(fields: [customerId], references: [id], onDelete: Cascade)
  adjustments ContractAdjustmentLog[]
  shareAllocations CustomerShare[]
}

model ContractAdjustmentLog {
  id               String   @id @default(cuid())
  contractId       String
  adjustedByUserId String
  reason           String
  fieldChanged     String
  oldValue         String
  newValue         String
  adjustedAt       DateTime @default(now())

  contract   CustomerContract @relation(fields: [contractId], references: [id], onDelete: Cascade)
  adjustedBy User             @relation(fields: [adjustedByUserId], references: [id])
}

model CustomerShare {
  id                 String        @id @default(cuid())
  customerId         String
  shareId            String
  allocatedAt        DateTime      @default(now())
  isActive           Boolean       @default(true)
  unitPrice          Float
  downpaymentPortion Float
  monthlyInstallment Float
  pricingSource      PricingSource @default(PHASE_DEFAULT)
  phaseId            Int?
  contractId         String?

  customer Customer          @relation(fields: [customerId], references: [id], onDelete: Cascade)
  share    Share             @relation(fields: [shareId], references: [id], onDelete: Cascade)
  contract CustomerContract? @relation(fields: [contractId], references: [id])

  @@index([shareId, isActive])
}

model PaymentLedger {
  id               String         @id @default(cuid())
  customerId       String
  purpose          PaymentPurpose
  installmentIndex Int?
  description      String?
  amountDue        Float
  amountPaid       Float          @default(0)
  status           PaymentStatus  @default(PENDING)
  paymentMethod    PaymentMethod?
  dueDate          DateTime?
  paidAt           DateTime?
  isFrozen         Boolean        @default(false)
  graceStatus      GraceStatus    @default(NONE)
  receiptId        String?
  settlementId     String?
  createdAt        DateTime       @default(now())
  updatedAt        DateTime       @updatedAt

  customer   Customer           @relation(fields: [customerId], references: [id], onDelete: Cascade)
  receipt    MoneyReceipt?      @relation(fields: [receiptId], references: [id])
  settlement PaymentSettlement? @relation(fields: [settlementId], references: [id])
  documents  Document[]

  @@unique([customerId, purpose, installmentIndex])
}

model PaymentSettlement {
  id                  String         @id @default(cuid())
  customerId          String
  settlementType      SettlementType
  totalAmountPaid     Float
  paymentMethod       PaymentMethod
  includeOptionalFees Boolean        @default(false)
  adminNote           String?
  settledAt           DateTime       @default(now())
  settledByUserId     String
  receiptId           String?        @unique

  customer    Customer        @relation(fields: [customerId], references: [id], onDelete: Cascade)
  settledBy   User            @relation("SettledBy", fields: [settledByUserId], references: [id])
  receipt     MoneyReceipt?   @relation(fields: [receiptId], references: [id])
  ledgerRows  PaymentLedger[]
}

model ReceiptCounter {
  id         String @id @default("global")
  lastSerial Int    @default(0)
}

model MoneyReceipt {
  id               String         @id @default(cuid())
  receiptSlNo      Int            @unique
  customerId       String
  purpose          PaymentPurpose
  installmentIndex Int?
  amount           Float
  paymentMethod    PaymentMethod
  status           ReceiptStatus  @default(ACTIVE)
  signatureAnchor  String
  pdfUrl           String?
  fileHash         String?
  issuedAt         DateTime       @default(now())
  voidedAt         DateTime?
  voidReason       String?

  customer        Customer           @relation(fields: [customerId], references: [id], onDelete: Cascade)
  ledgerEntries   PaymentLedger[]
  settlement      PaymentSettlement?
}

model ShareTransferLog {
  id                   String   @id @default(cuid())
  fromCustomerId       String
  toCustomerId         String
  shareId              String
  cutoffInstallment    Int
  transferDate         DateTime @default(now())
  digitalLogSignature  String

  fromCustomer Customer   @relation("TransferFrom", fields: [fromCustomerId], references: [id])
  toCustomer   Customer   @relation("TransferTo", fields: [toCustomerId], references: [id])
  share        Share      @relation(fields: [shareId], references: [id])
  documents    Document[]
}

model Document {
  id              String   @id @default(cuid())
  fileUrl         String
  sha256Hash      String
  isSoftLocked    Boolean  @default(false)
  isPublic        Boolean  @default(false)
  label           String?
  mimeType        String?
  fileSize        Int?
  projectId       String?
  customerId      String?
  transferLogId   String?
  paymentLedgerId String?
  createdAt       DateTime @default(now())

  project       Project?          @relation(fields: [projectId], references: [id])
  customer      Customer?         @relation(fields: [customerId], references: [id])
  transferLog   ShareTransferLog? @relation(fields: [transferLogId], references: [id])
  paymentLedger PaymentLedger?    @relation(fields: [paymentLedgerId], references: [id])
}

model CustomerNote {
  id         String   @id @default(cuid())
  customerId String
  body       String
  authorId   String
  createdAt  DateTime @default(now())

  customer Customer @relation(fields: [customerId], references: [id], onDelete: Cascade)
  author   User     @relation(fields: [authorId], references: [id])
}

model AuditLog {
  id         String   @id @default(cuid())
  action     String
  entityType String
  entityId   String
  userId     String
  payload    String   @default("{}")
  ipAddress  String?
  createdAt  DateTime @default(now())

  user User @relation(fields: [userId], references: [id])
}

model CompanyExpense {
  id               String           @id @default(cuid())
  voucherNo        String           @unique
  category         ExpenseCategory
  description      String?
  amount           Float
  expenseDate      DateTime
  isProjectExpense Boolean          @default(false)
  projectId        String?
  approvedBy       ApprovingPartner
  recordedByUserId String
  createdAt        DateTime         @default(now())
  updatedAt        DateTime         @updatedAt

  project    Project? @relation(fields: [projectId], references: [id])
  recordedBy User     @relation(fields: [recordedByUserId], references: [id])

  @@index([expenseDate])
  @@index([category])
  @@index([isProjectExpense])
}

model Lead {
  id                   String     @id @default(cuid())
  fullName             String
  phone                String
  email                String?
  source               LeadSource @default(PHONE)
  status               LeadStatus @default(NEW)
  interestNotes        String?
  projectId            String?
  assignedToUserId     String?
  salesAgentId         String?
  nextFollowUpAt       DateTime?
  siteVisitAt          DateTime?
  siteVisitNotes       String?
  lostReason           String?
  convertedCustomerId  String?
  createdAt            DateTime   @default(now())
  updatedAt            DateTime   @updatedAt

  project           Project?    @relation(fields: [projectId], references: [id])
  assignedTo        User?       @relation("LeadAssignee", fields: [assignedToUserId], references: [id])
  salesAgent        SalesAgent? @relation(fields: [salesAgentId], references: [id])
  convertedCustomer Customer?   @relation("LeadConvertedCustomer", fields: [convertedCustomerId], references: [id])
  reminders         Reminder[]
  commissions       Commission[]

  @@index([status])
  @@index([phone])
  @@index([nextFollowUpAt])
  @@index([salesAgentId])
}

model Reminder {
  id               String         @id @default(cuid())
  title            String
  type             ReminderType   @default(FOLLOW_UP)
  status           ReminderStatus @default(PENDING)
  dueAt            DateTime
  notes            String?
  leadId           String?
  customerId       String?
  createdByUserId  String
  completedAt      DateTime?
  createdAt        DateTime       @default(now())
  updatedAt        DateTime       @updatedAt

  lead      Lead?     @relation(fields: [leadId], references: [id], onDelete: Cascade)
  customer  Customer? @relation(fields: [customerId], references: [id], onDelete: Cascade)
  createdBy User      @relation(fields: [createdByUserId], references: [id])

  @@index([status, dueAt])
  @@index([leadId])
  @@index([customerId])
}

model SalesAgent {
  id                   String   @id @default(cuid())
  fullName             String
  phone                String
  email                String?
  isActive             Boolean  @default(true)
  defaultCommissionPct Float    @default(2)
  notes                String?
  userId               String?  @unique
  createdAt            DateTime @default(now())
  updatedAt            DateTime @updatedAt

  user         User?        @relation(fields: [userId], references: [id])
  leads        Lead[]
  customers    Customer[]
  commissions  Commission[]

  @@index([isActive])
  @@index([phone])
}

model Commission {
  id           String           @id @default(cuid())
  agentId      String
  customerId   String?
  leadId       String?
  projectId    String?
  basis        CommissionBasis  @default(DOWNPAYMENT)
  status       CommissionStatus @default(PENDING)
  ratePercent  Float
  baseAmount   Float
  amount       Float
  notes        String?
  paidAt       DateTime?
  createdAt    DateTime         @default(now())
  updatedAt    DateTime         @updatedAt

  agent    SalesAgent @relation(fields: [agentId], references: [id])
  customer Customer?  @relation(fields: [customerId], references: [id])
  lead     Lead?      @relation(fields: [leadId], references: [id])
  project  Project?   @relation(fields: [projectId], references: [id])

  @@index([status])
  @@index([agentId])
  @@index([customerId])
  @@index([createdAt])
}

model LandValuation {
  id               String   @id @default(cuid())
  projectId        String
  valuedAt         DateTime
  landValue        Float
  notes            String?
  recordedByUserId String
  createdAt        DateTime @default(now())

  project    Project @relation(fields: [projectId], references: [id], onDelete: Cascade)
  recordedBy User    @relation(fields: [recordedByUserId], references: [id])

  @@index([projectId, valuedAt])
}

model DeveloperAgreement {
  id                    String                    @id @default(cuid())
  projectId             String
  developerName         String
  contactPhone          String?
  contactEmail          String?
  signedAt              DateTime?
  ourSharePercent       Float?
  developerSharePercent Float?
  constructionStart     DateTime?
  expectedCompletion    DateTime?
  status                DeveloperAgreementStatus  @default(DRAFT)
  milestones            String                    @default("[]")
  notes                 String?
  createdAt             DateTime                  @default(now())
  updatedAt             DateTime                  @updatedAt

  project Project @relation(fields: [projectId], references: [id], onDelete: Cascade)

  @@index([projectId])
  @@index([status])
}

model Flat {
  id         String     @id @default(cuid())
  projectId  String
  code       String
  building   String?
  floor      Int?
  flatNumber String?
  sizeSqft   Float?
  bedrooms   Int?
  status     FlatStatus @default(PLANNED)
  customerId String?
  notes      String?
  createdAt  DateTime   @default(now())
  updatedAt  DateTime   @updatedAt

  project  Project         @relation(fields: [projectId], references: [id], onDelete: Cascade)
  customer Customer?       @relation(fields: [customerId], references: [id])
  shareLinks FlatShareLink[]
  handovers  Handover[]

  @@unique([projectId, code])
  @@index([projectId, status])
  @@index([customerId])
}

model FlatShareLink {
  id        String   @id @default(cuid())
  flatId    String
  shareId   String   @unique
  createdAt DateTime @default(now())

  flat  Flat  @relation(fields: [flatId], references: [id], onDelete: Cascade)
  share Share @relation(fields: [shareId], references: [id], onDelete: Cascade)

  @@index([flatId])
}

model Handover {
  id                 String         @id @default(cuid())
  projectId          String
  customerId         String
  flatId             String?
  status             HandoverStatus @default(NOT_STARTED)
  keysDelivered      Boolean        @default(false)
  documentsDelivered Boolean        @default(false)
  snagNotes          String?
  notes              String?
  handedOverAt       DateTime?
  recordedByUserId   String?
  createdAt          DateTime       @default(now())
  updatedAt          DateTime       @updatedAt

  project    Project   @relation(fields: [projectId], references: [id], onDelete: Cascade)
  customer   Customer  @relation(fields: [customerId], references: [id], onDelete: Cascade)
  flat       Flat?     @relation(fields: [flatId], references: [id])
  recordedBy User?     @relation("HandoverRecorder", fields: [recordedByUserId], references: [id])

  @@unique([customerId])
  @@index([projectId, status])
}
