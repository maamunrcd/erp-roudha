# Pooled URL (Neon "-pooler" host) — app runtime; add &pgbouncer=true when pooled
DATABASE_URL="postgresql://USER:PASSWORD@HOST-pooler.region.aws.neon.tech/neondb?sslmode=require&pgbouncer=true"
# Required for migrate deploy on Neon: direct host (no "-pooler", no pgbouncer=true)
DATABASE_URL_UNPOOLED="postgresql://USER:PASSWORD@HOST.region.aws.neon.tech/neondb?sslmode=require"
AUTH_SECRET="generate-with-openssl-rand-hex-32"
RECEIPT_SECRET="generate-with-openssl-rand-hex-32"
# Local only — do NOT set to localhost on Vercel (omit AUTH_URL there; Auth.js infers the host)
AUTH_URL="http://localhost:3000"
SEED_ADMIN_EMAIL="admin@raudha.properties"
SEED_ADMIN_PASSWORD="changeme"
